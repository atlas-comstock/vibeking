# Copy values into Render / Vercel dashboards — do not commit real secrets.

# Neon (https://console.neon.tech)
DATABASE_URL=postgresql://USER:PASS@HOST/neondb?sslmode=require

# Render API service
API_BASE_URL=https://vibeking-api.onrender.com
SITE_BASE_DOMAIN=vibeking-api.onrender.com
WEB_ORIGIN=https://vibeking.vercel.app
GITHUB_CALLBACK_URL=https://vibeking-api.onrender.com/api/v1/auth/github/callback
SESSION_SECRET=generate-a-long-random-string
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloudflare R2
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_BUCKET=vibeking
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_FORCE_PATH_STYLE=false

# Vercel (apps/web)
NEXT_PUBLIC_API_URL=https://vibeking-api.onrender.com/api/v1
NEXT_PUBLIC_WEB_ORIGIN=https://vibeking.vercel.app
NEXT_PUBLIC_PREVIEW_ORIGIN=https://vibeking-api.onrender.com